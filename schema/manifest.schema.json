{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Manifest",
  "type": "object",
  "required": ["version", "blog", "categories", "directories", "articles", "map_memos"],
  "properties": {
    "version": { "type": "integer", "const": 1 },
    "blog": {
      "type": "object",
      "required": ["name", "sidebar"],
      "properties": {
        "name": { "type": "string" },
        "top_image_id": { "type": "string", "format": "uuid" },
        "sidebar": {
          "type": "object",
          "required": ["panels"],
          "properties": {
            "panels": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["kind", "visible"],
                "properties": {
                  "kind": { "type": "string", "enum": ["gpx_map", "categories", "monthly"] },
                  "visible": { "type": "boolean" }
                }
              }
            }
          }
        }
      }
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "priority"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "name": { "type": "string" },
          "priority": { "type": "integer" }
        }
      }
    },
    "directories": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" }
        }
      }
    },
    "articles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "status", "category_ids", "created_at"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "title": { "type": "string" },
          "status": { "type": "string", "enum": ["published", "draft"] },
          "category_ids": { "type": "array", "items": { "type": "string", "pattern": "^[a-z0-9-]+$" } },
          "thumbnail_file_id": { "type": "string", "format": "uuid" },
          "gpx_file_id": { "type": "string", "format": "uuid" },
          "created_at": { "type": "integer" }
        }
      }
    },
    "map_memos": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "kind", "lat", "lng", "memo"],
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "kind": { "type": "integer" },
          "lat": { "type": "number" },
          "lng": { "type": "number" },
          "memo": { "type": "string" },
          "image_id": { "type": "string", "format": "uuid" }
        }
      }
    }
  }
}
